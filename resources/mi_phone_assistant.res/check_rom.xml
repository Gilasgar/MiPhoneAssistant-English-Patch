<?xml version="1.0" encoding="utf-8"?>
<Window size="720,465" mininfo="720,460" caption="0,0,0,80" showdirty="false">
  <Include source="style.xml" />
  <VerticalLayout name="bg" childalign="center" align="center">
  
	<TabLayout name="check_tab" selectedid="0">
		<!-- localized -->
		<VerticalLayout name="ing_layout" >
			<VerticalLayout height="120" />
			<VerticalLayout name="checking" width="74" height="74" >
				<GifAnim bkimage="imgs/loading_op.gif" width="74" height="74"/>
			</VerticalLayout>
			<VerticalLayout height="25" />
			<HorizontalLayout height="30">
				<HorizontalLayout width="240" />
				<Label name="ing_tip" text="Verifying selected flash package" font="18" width="200" textcolor="#444c58" />
				<HorizontalLayout width="2" />
				<VerticalLayout width="18" >
					<VerticalLayout height="19" />
					<GifAnim bkimage="imgs/point.gif" width="18" height="5"/>
				</VerticalLayout>
			</HorizontalLayout >
			<Label name="ing_rom" text="Current flash package: 1212121212121211121212.zip" height="20" textcolor="#8b94a5"  />
			<Label text="Verifying a flash package usually takes 10 to 30 seconds. Do not disconnect the phone" font="13" height="30" textcolor="#8b94a5"/>
			<VerticalLayout height="100" />
			<Button name="ing_select" text="Select Flash Package Again" font="14" textcolor="#444c58" height="38" width="130" />
		</VerticalLayout>
		
		<!-- localized -->
		<VerticalLayout name="err_layout" >
			<VerticalLayout height="120" />
			<Control bkimage="imgs\err.png" height="74" width="74"/>
			<VerticalLayout height="25" />
			<Label name="err_tip" text="Flash package verification failed" font="18" textcolor="#444c58" />
			<Label name="err_rom" text="Current flash package: 1212121212121211121212.zip" font="15" height="20" textcolor="#8b94a5"  />
			<Label name="suggest_rom" text="Current flash package: 1212121212121211121212.zip" font="15" height="30" textcolor="#f16362"/>
			<VerticalLayout height="100" />
			<Button name="err_select" text="Select Flash Package Again" font="14" textcolor="#444c58" height="38" width="130" />
		</VerticalLayout>
		
		<!-- localized -->
		<VerticalLayout name="clearn_layout" >
			<VerticalLayout height="120" />
			<Control bkimage="imgs\waring.png" height="74" width="74"/>
			<VerticalLayout height="25" />
			<Label name="clearn_tip" text="Erase data and update?" font="18" textcolor="#444c58" />
			<Label name="clearn_msg" text="Switching between stable and developer builds will erase data. Phone data will be lost!" font="15" height="20" textcolor="#8b94a5"  />
			<VerticalLayout height="110" />
			<HorizontalLayout childalign="center" childvalign="enter">
				<Button name="sure" text="Update" font="14" textcolor="#444c58" padding="220,0,50,0" height="38" width="110" />
				<Button name="cancel" text="Do Not Update" font="14" textcolor="#444c58" height="38" width="110" />
			</HorizontalLayout>
		</VerticalLayout>
		
		<!-- localized -->
		<VerticalLayout name="clearn_sec_layout" >
			<VerticalLayout height="120" />
			<Control bkimage="imgs\waring.png" height="74" width="74"/>
			<VerticalLayout height="25" />
			<Label text="Confirm data erase?" font="18" textcolor="#444c58" />
			<Label text="Erase data. Data on the phone will be lost" font="15" height="20" textcolor="#8b94a5"  />
			<VerticalLayout height="110" />
			<HorizontalLayout childalign="center" childvalign="enter">
				<Button name="sure_sec" text="Erase" font="14" textcolor="#444c58" padding="220,0,50,0" height="38" width="110" />
				<Button name="cancel_sec" text="Do Not Erase" font="14" textcolor="#444c58" height="38" width="110" />
			</HorizontalLayout>
		</VerticalLayout>
	</TabLayout>
  </VerticalLayout>
</Window>
